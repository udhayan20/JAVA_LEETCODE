class Solution 
{
    public int binaryGap(int n) 
    {
        int res = 0;
        int prev = -1; 
        int c = 0; 

        while ((n & 1) == 0) {
            c++;
            n >>= 1;
        }

        prev = c; 

        while (n > 0) {
            if ((n & 1) == 1) 
            { 
                res = Math.max(res, c - prev);  
                prev = c;                
            }
            c++;       
            n >>= 1;   
        }
        return res;
    }
}
