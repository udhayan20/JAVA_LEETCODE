class Solution 
{
    public int bitwiseComplement(int n) 
    {
        int m = n;
        int res = 0;
        if (n == 0) {
            return 1;
        }
        while (m != 0) {
            res = (res << 1) | 1;
            m = m >> 1;
        }
        int ans = (~n) & res;
        return ans;
    }
}
