class Solution 
{
    public int closestTarget(String[] words, String target, int startIndex) 
    {
        int n = words.length;
        int dis = n;

        for (int i = 0; i < n; i++) 
        {
            if (target.equals(words[i])) 
            {
                int gap = Math.abs(startIndex - i);
                int cir = Math.min(gap, n - gap);
                dis = Math.min(dis, cir);
            }
        }
        return (dis == n) ? -1 : dis;
    }
}
